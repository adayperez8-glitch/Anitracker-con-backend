              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/anime/{{animeId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "anime", "{{animeId}}"]
            }
          }
        }
      ]
    },
